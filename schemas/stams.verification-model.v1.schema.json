{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "stams.verification-model.v1",
  "title": "StaMS verification model",
  "description": "Executable structural snapshot of a state machine for simulation and verification.",
  "type": "object",
  "required": ["$schema", "version", "machines"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "const": "stams.verification-model.v1"
    },
    "version": {
      "const": 1
    },
    "machines": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/machine" }
    }
  },
  "$defs": {
    "machine": {
      "type": "object",
      "required": ["name", "variables", "events", "actions", "guards", "states", "transitions"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "variables": {
          "type": "array",
          "items": { "$ref": "#/$defs/variable" }
        },
        "events": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "actions": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/action" }
        },
        "guards": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/guard" }
        },
        "states": {
          "type": "array",
          "items": { "$ref": "#/$defs/state" }
        },
        "transitions": {
          "type": "array",
          "items": { "$ref": "#/$defs/transition" }
        }
      }
    },
    "variable": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "enum": ["int", "float", "bool", "string"] },
        "init": { "$ref": "#/$defs/expr" }
      }
    },
    "action": {
      "type": "object",
      "required": ["statements"],
      "additionalProperties": false,
      "properties": {
        "statements": {
          "type": "array",
          "items": { "$ref": "#/$defs/statement" }
        }
      }
    },
    "guard": {
      "type": "object",
      "required": ["expr"],
      "additionalProperties": false,
      "properties": {
        "expr": { "$ref": "#/$defs/expr" }
      }
    },
    "state": {
      "type": "object",
      "required": ["name", "isInitial", "isFinal"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "isInitial": { "type": "boolean" },
        "isFinal": { "type": "boolean" },
        "entry": { "type": ["string", "null"] },
        "run": { "type": ["string", "null"] },
        "exit": { "type": ["string", "null"] }
      }
    },
    "transition": {
      "type": "object",
      "required": ["id", "source", "target", "event"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "event": { "type": "string", "minLength": 1 },
        "guard": { "type": ["string", "null"] },
        "action": { "type": ["string", "null"] }
      }
    },
    "statement": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "target", "expr"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "assign" },
            "target": { "type": "string", "minLength": 1 },
            "expr": { "$ref": "#/$defs/expr" }
          }
        },
        {
          "type": "object",
          "required": ["kind", "expr"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "expr" },
            "expr": { "$ref": "#/$defs/expr" }
          }
        }
      ]
    },
    "expr": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "value"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "number" },
            "value": { "type": "number" }
          }
        },
        {
          "type": "object",
          "required": ["kind", "value"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "string" },
            "value": { "type": "string" }
          }
        },
        {
          "type": "object",
          "required": ["kind", "value"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "bool" },
            "value": { "type": "boolean" }
          }
        },
        {
          "type": "object",
          "required": ["kind", "name"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "var" },
            "name": { "type": "string", "minLength": 1 }
          }
        },
        {
          "type": "object",
          "required": ["kind", "op", "left", "right"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "binary" },
            "op": {
              "enum": ["+", "-", "*", "/", "==", "!=", "<", "<=", ">", ">=", "&&", "||"]
            },
            "left": { "$ref": "#/$defs/expr" },
            "right": { "$ref": "#/$defs/expr" }
          }
        },
        {
          "type": "object",
          "required": ["kind", "op", "arg"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "unary" },
            "op": { "enum": ["!", "-"] },
            "arg": { "$ref": "#/$defs/expr" }
          }
        },
        {
          "type": "object",
          "required": ["kind", "name", "args"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "call" },
            "name": { "type": "string", "minLength": 1 },
            "args": {
              "type": "array",
              "items": { "$ref": "#/$defs/expr" }
            }
          }
        }
      ]
    }
  }
}
