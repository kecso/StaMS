{
  "name": "state-machine",
  "scopeName": "source.state-machine",
  "fileTypes": [
    ".sm"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "name": "keyword.control.state-machine",
      "match": "\\b(actions|constraints|description|do|entry|events|exit|final|float|goal|guard|guards|inState|initial|machine|on|run|safety|state|string|variables)\\b"
    },
    {
      "name": "string.quoted.double.state-machine",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "include": "#string-character-escape"
        }
      ]
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.state-machine",
          "begin": "/\\*",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.state-machine"
            }
          },
          "end": "\\*/",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.comment.state-machine"
            }
          }
        },
        {
          "begin": "//",
          "beginCaptures": {
            "1": {
              "name": "punctuation.whitespace.comment.leading.state-machine"
            }
          },
          "end": "(?=$)",
          "name": "comment.line.state-machine"
        }
      ]
    },
    "string-character-escape": {
      "name": "constant.character.escape.state-machine",
      "match": "\\\\(x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4}|u\\{[0-9A-Fa-f]+\\}|[0-2][0-7]{0,2}|3[0-6][0-7]?|37[0-7]?|[4-7][0-7]?|.|$)"
    }
  }
}
