machine Vending {
  description "Idle, selection, and dispensing flow."

  events { coin select dispense cancel }
  actions {
    acceptPayment { }
    releaseItem { }
    refund { }
  }
  initial state Idle {
    on coin -> Selecting do acceptPayment
  }
  state Selecting {
    on select -> Dispensing
    on cancel -> Idle do refund
  }
  state Dispensing {
    entry releaseItem
    on dispense -> Idle
  }
}
